{
  "name": "hey-clarissa",
  "version": "0.0.1",
  "description": "Clarissa — make your terminal feel like yours",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
